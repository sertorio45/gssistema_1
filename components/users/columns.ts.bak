import type { ColumnDef } from '@tanstack/vue-table'
import type { User } from '~/composables/useUsers'
import { h } from 'vue'
import DataTableColumnHeader from './DataTableColumnHeader.vue'
import DataTableRowActions from './DataTableRowActions.vue'

export function columns(emit: (event: 'edit' | 'delete', user: User) => void): ColumnDef<User, any>[] {
  return [
    {
      id: 'select',
      header: ({ table }) =>
        h('div', { class: 'px-1' }, [
          h('Checkbox', {
            'checked': table.getIsAllPageRowsSelected(),
            'tristate': table.getIsSomePageRowsSelected(),
            'onUpdate:checked': (value: boolean) => table.toggleAllPageRowsSelected(!!value),
            'ariaLabel': 'Selecionar tudo',
            'class': 'translate-y-[2px]',
          }),
        ]),
      cell: ({ row }) =>
        h('div', { class: 'px-1' }, [
          h('Checkbox', {
            'checked': row.getIsSelected(),
            'disabled': !row.getCanSelect(),
            'onUpdate:checked': (value: boolean) => row.toggleSelected(!!value),
            'ariaLabel': 'Selecionar linha',
            'class': 'translate-y-[2px]',
          }),
        ]),
      enableSorting: false,
      enableHiding: false,
    },
    {
      accessorKey: 'email',
      header: ({ column }) =>
        h(DataTableColumnHeader, {
          column,
          title: 'Email',
        }),
      cell: ({ row }) => h('div', { class: 'text-muted-foreground' }, row.getValue('email')),
      enableSorting: true,
      enableHiding: true,
    },
    {
      accessorKey: 'role',
      header: ({ column }) =>
        h(DataTableColumnHeader, {
          column,
          title: 'Função',
        }),
      cell: ({ row }) => {
        const role = row.getValue('role') as string
        
        interface Badge {
          class: string
          icon: string
          label: string
        }
        
        const badges: Record<string, Badge> = {
          admin: {
            class: 'border bg-purple-100 text-purple-700 dark:bg-purple-900/40 dark:text-purple-300',
            icon: 'lucide:shield',
            label: 'Administrador',
          },
          funcionario: {
            class: 'border bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300',
            icon: 'lucide:briefcase',
            label: 'Funcionário',
          },
          cliente: {
            class: 'border bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-300',
            icon: 'lucide:user',
            label: 'Cliente',
          },
        }

        const badge = badges[role] || badges.cliente

        return h(
          'div',
          {
            class: `inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium ${badge.class}`,
          },
          [
            h('Icon', {
              name: badge.icon,
              class: 'mr-1 h-3.5 w-3.5',
            }),
            badge.label,
          ],
        )
      },
      filterFn: (row, id, value) => {
        return value.includes(row.getValue(id))
      },
      enableSorting: true,
      enableHiding: true,
    },
    {
      accessorKey: 'created_at',
      header: ({ column }) =>
        h(DataTableColumnHeader, {
          column,
          title: 'Criado em',
        }),
      cell: ({ row }) => {
        const date = new Date(row.getValue('created_at'))
        return h('div', { class: 'text-muted-foreground' }, date.toLocaleDateString('pt-BR'))
      },
      enableSorting: true,
      enableHiding: true,
    },
    {
      id: 'actions',
      cell: ({ row }) => h(DataTableRowActions, {
        row,
        onEdit: () => emit('edit', row.original),
        onDelete: () => emit('delete', row.original),
      }),
      enableSorting: false,
      enableHiding: false,
    },
  ]
} 