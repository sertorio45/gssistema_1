# Ollama (agentes IA)
OLLAMA_BASE_URL=https://ollama.gsstudio.com.br
OLLAMA_DEFAULT_MODEL=qwen
OLLAMA_CF_ACCESS_CLIENT_ID=
OLLAMA_CF_ACCESS_CLIENT_SECRET=

# OpenAI (opcional — fallback se agente usar provider openai)
OPENAI_API_KEY=

# --- Vercel (Production) ---
# Bypass por IP NÃO funciona — use Service Token CF-Access acima.
# Vercel Dashboard → Project → Settings → Environment Variables → Production
# Adicione as 4 variáveis OLLAMA_* e faça Redeploy.
# Cloudflare Zero Trust → app Ollama → Policy: Include → Service Token
